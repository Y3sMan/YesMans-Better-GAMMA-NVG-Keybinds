--  ----------    on_key_release functions -------

---Adjust Beef's NVG Brightness
function adjust_nods_brightness_key_release()
    -- reset bas bino and scope nvg status
    toggle_scope_nvg(false)


    local nvg_bind = other_mod_keys.item_device.nvg.bind
    local key = bind_to_dik(nvg_bind)
    _item_device_key_release(key)
end

---Reset Beef's NVG Time Event that toggles nods on/off
function nods_keypress_release()
    RemoveTimeEvent("nvg_keypress", "nvg_keypress_long")
end

---Dosimeter Hotkey
function dosimeter_key_release()
    local dosimeter_bind = other_mod_keys.item_device.dosimeter.bind
    local key = bind_to_dik(dosimeter_bind)

    -- for some reason holding_shift gets stuck somewhere between this mod's
    -- on_key_release and the execution of this function
    -- we have to reset holding_shift ourselves
    if not ui_mcm.MOD_SHIFT then
        item_device.holding_shift = false
    end

    -- debug("dosimeter key = %s", key)
    _item_device_key_release(key)
end
