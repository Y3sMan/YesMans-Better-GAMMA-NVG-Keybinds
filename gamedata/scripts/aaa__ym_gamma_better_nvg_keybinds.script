function on_mcm_load()

-- new template from Soulslike. Thanks Jabbers
	local options = {
		id = mod_id,
		gr = {}
	}

	local scopes_and_nvg = {
		id = "scopes_and_nvg",
		text = ui_mcm_mod_id .. "scopes_and_nvg",
		sh = true,
		gr = {
			{
				id = "title",
				type = "title",
				-- text = "Binoculars and Scopes NVG Toggle Key",
				text = "test_title",
				size = { 512, 50 },
				spacing = 20
			},
			{
				id = "keybind",
				type = "key_bind",
				val = 2,
				def = defaults.scope_bino_nvg_key.key
			},
			{
				id = "mode",
				type = ui_mcm.kb_mod_radio,
				val = 2,
				def = 0,
				hint = "mcm_kb_mode",
				content = {
					{ 0, "mcm_kb_mode_press" },
					{ 1, "mcm_kb_mode_dtap" },
					{ 2, "mcm_kb_mode_hold" }
				}
			},
			{
				id = "modifier",
				type = ui_mcm.kb_mod_radio,
				val = 2,
				def = 0,
				hint = "mcm_kb_modifier",
				content = {
					{ 0, "mcm_kb_mod_none" },
					{ 1, "mcm_kb_mod_shift" },
					{ 2, "mcm_kb_mod_ctrl" },
					{ 3, "mcm_kb_mod_alt" },
				}
			}
		}
	}

	options.gr[#options.gr + 1] = scopes_and_nvg

	return options
end

function on_option_change(mcm)
    if (not mcm) then return end
	ym_better_keys["scopes_and_nvg"] = get_scopes_and_nvg_key() or nil
    other_mod_keys.z_mark_switch.mark_switch.key = z_mark_switch_mcm.get_config("keybind") or DIK_keys.DIK_EQUALS
end

--- Patches other scripts to unregister their key events
function patches()

end



function first_update()
    -- turn off bino and scope nvg every load
    -- stop blinding yourself during the day
    toggle_scope_nvg(false)

    -- patches other scripts
    patches()
end

function on_game_start()

    -- force load-order. doesnt seem to work
    -- if z_mark_switch.on_game_start then end
    -- if bas_nvg_scopes.on_game_start then end
    -- if item_device then end

    patches()

    RegisterScriptCallback("actor_on_first_update", first_update)
    RegisterScriptCallback("actor_on_weapon_zoom_in", on_zoom_in)
    RegisterScriptCallback("on_option_change", on_option_change)
	RegisterScriptCallback("on_key_hold", on_key_hold)
	RegisterScriptCallback("on_key_press", on_key_press)
	RegisterScriptCallback("on_key_release", on_key_release)

    -- ----- mcm -------------
    on_option_change(mcm_keybinds)
end
