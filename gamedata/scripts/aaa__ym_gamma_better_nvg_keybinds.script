--#region MCM Option Getters

local function get_config(key, default_when_nil)
    local opt = ui_mcm and ui_mcm.get(mod_id .. "/"..key)
    if opt == nil then
        opt = default_when_nil
    end
    return opt
end

function get_scopes_and_nvg_key()
	--[[
		returns a table containing:
			keybind,
			mode,
			modifier (mod)
	--]]
	local key_info = {
		["key"] = nil,
		["mod"] = nil,
		["mode"] = nil
	}
	key_info.key = get_config("scopes_and_nvg/keybind", defaults.scope_bino_nvg_key.key)
	key_info.mode = get_config("scopes_and_nvg/mode", defaults.scope_bino_nvg_key.mode)
	key_info.mod = get_config("scopes_and_nvg/modifier", defaults.scope_bino_nvg_key.mod)

	return key_info
end

--#endregion

--#region Main


--[[
    item_device.script:
        - holding_shift check
--]]
function on_key_hold(key)
	-- throttle(debug("other hold keys"), 1000)
    _item_device_key_hold(key)
end


--[[
    item_device.script:
        - night vision brightness adjust
        - dosimeter hotkey
    bas_nvg_scopes.script:
        - nvg toggle
    z_mark_switch.script:
        - scope marker switch (and nvg scope toggle)
--]]
function on_key_release(key)
    local bind = dik_to_bind(key)
	-- debug("release event")
    if (bind == key_bindings.kNIGHT_VISION) then
        nods_keypress_release() -- item_device

        nv_state = item_device.nv_state
        -- debug("nv_state = %s", nv_state)
        if nv_state then
            if ui_mcm[MARK_SWITCH_MODIFIER_MODE] then
                mark_switch_release()
            else
                adjust_nods_brightness_key_release() --item_device
            end
        elseif is_weapon_zoomed() then
            -- debug("bino nvg toggle")
            bas_nvg_toggle() -- bas_nvg_scopes
            mark_switch_release() -- mark_switch 
        end
    elseif (bind == key_bindings.kCUSTOM14) then
        dosimeter_key_release() -- item_device
        -- _item_device_key_release(key)
    end
end

--[[
    item_device.script:
        -nods activate
    bas_nvg_scopes.script:
        - switching_sight (remove nvg)
--]]
function on_key_press(key)
    -- debug("press event")
    -- if (key == DIK_keys.DIK_N) then
    -- end
    _item_device_key_press(key)
    _bas_nvg_scopes_key_press(key)
end



-- TODO: Check xp3eotec folding scope. Reticle missing?
function on_zoom_in(obj)
    if not (db.actor and db.actor:alive()) then return end

    nv_state = item_device.nv_state
    local bas_toggle = bas_nvg_scopes.toggle
    -- debug("nv_state = %s", nv_state)
    -- debug("bas_nvg = %s", bas_toggle)

	local wpn = db.actor:active_item()
    if not wpn then return end

    local is_ms_nvg = is_mark_nvg(wpn) or false

    if is_ms_nvg then 
        deactivate_mark_nvg(wpn)
    end


    if nv_state and bas_toggle then
        toggle_scope_nvg(false)
    end
end


