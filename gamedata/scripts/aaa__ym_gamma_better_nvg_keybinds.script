--#region ======= z_mark_switch.script             =======================================================
-----------     on_key_release -----------------------------


function mark_switch_release()
    local key = other_mod_keys.z_mark_switch.mark_switch.key
    _mark_switch_key_release(key)
end

function is_mark_nvg(wpn)
    if not wpn then return end

    --[[
        we need to grab the s3ds_image_type from the scope config 
        s3ds_image_type = 1 is an nvg scope
        with ms_count = 2, it is toggleable
    --]]

    -- debug("current marks:")
    print_table(z_mark_switch.current_marks)

    
    -- get the scope attached to the parameter gun wpn
    local attached_scope = utils_item.get_attached_scope(wpn, false)
    -- check if wpn has a scope, or wpn is actually the binoculars
    if not attached_scope and not string_find(wpn:section(), "wpn_binoc") then return end
    -- debug("scope = %s", attached_scope)

    local ms_nvg = false
     
    -- start parsing z_mark_switch information
    local info = parse_parameters(wpn)
    -- debug("ms info:")
    print_table(info)

    -- how many mark switches the scope has
    -- if we have an nvg scope, and ms_count = 2, then nvg state can be toggled off
    local ms_count = info.ms_count or -1

    -- check if scope is legit
    -- binocs get up to this point, but attached_scope still = false
    if attached_scope then
        -- image_type is what actually defines if its an nvg scope or not
        --[[
            from mod_system_3dss_gamma_scopes.ltx:
            ```
                ; s3ds_image_type - background image processor (default 0)
                ;   0 - none
                ;   1 - NV scope (with ms_count = 2 becomes switchable)
                ;   2 - thermal scope (with ms_count = 2 becomes switchable white-hot/black-hot, with ms_count = 3 becomes also switchable on/off)
                ;   3 - Colored thermal scope (same as previous)
            ```
        --]]
        local image_type = attached_scope and utils_item.get_param(attached_scope, nil, "s3ds_image_type", "string") or 0
        image_type = tonumber(image_type) or 0
        -- debug("image type = %s, ms_count = %s", image_type, ms_count)

        -- if scope is an nvg (or thermal) scope AND we can switch nvgs off
        if (ms_count > 1) and (image_type >= 1) and nv_state then
            ms_nvg = true
        end
    end

    return ms_nvg
end

---Deactivate mark_switch nvg scopes
---does not touch any other scopes
function deactivate_mark_nvg(wpn)
    if not wpn then return end

    local info = parse_parameters(wpn)
    -- debug("ms info:")
    print_table(info)

    local new_info = info
    new_info.ms_current = 1
    z_mark_switch.current_marks[wpn:id()] = 1
    update_shader(nil, new_info)
end


