--#region utilities

--#region helpers
function is_bino_upgraded()
    local is_upgraded = false
    local weapon = db.actor:active_item()

    -- player has bino check
    if not weapon or not string_find(weapon:section(),"wpn_binoc") then return is_upgraded end

    local wpn_sec = weapon:section()
    if utils_item.has_this_upgrade(weapon, wpn_sec, "up_secone_binoc") or
        utils_item.has_this_upgrade(weapon, wpn_sec, "up_seconc_binoc") or
        utils_item.has_this_upgrade(weapon, wpn_sec, "up_secona_binoc") then
        is_upgraded = true
    end

    return is_upgraded
end

function is_weapon_zoomed()
	local weapon_zoomed = axr_main.weapon_is_zoomed and (not (IsPistol(db.actor:active_item(),nil)) or db.actor:active_detector())
    return weapon_zoomed or false
end

-- Control NVG state of bas_nvg_scopes
--- @param on_off boolean 
---| 'true' toggles on only
---| 'false' toggles off only
---| 'nil' toggles back and forth
---@return nil
function toggle_scope_nvg(on_off)
    -- either set bas_bino nvg state
    -- or simply toggle it, if on_off = nil
    local toggle = bas_nvg_scopes.toggle
    if on_off ~= nil then
        bas_nvg_scopes.toggle = on_off
    else
        bas_nvg_scopes.toggle = not toggle
    end 

    toggle = bas_nvg_scopes.toggle
    if on_off or toggle then
        bas_nvg_scopes.activate()
    else
        bas_nvg_scopes.deactivate()
    end
end
